NODE_ENV=development
PORT=4000

MONGODB_URI=mongodb://localhost:27017/ums

# 32+ chars recommended
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh

ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

# Frontend origin for CORS (Render static site URL or local dev URL)
CORS_ORIGIN=http://localhost:5173

# Refresh cookie settings
REFRESH_COOKIE_NAME=ums_refresh

# Optional seed (creates admin if not exists)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin123!ChangeMe
SEED_ADMIN_NAME=Admin
